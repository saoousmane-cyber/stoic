# AURA & LOGOS - Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs

# ============================================
# AUTHENTIFICATION
# ============================================

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ============================================
# BASE DE DONNÉES & CACHE
# ============================================

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# ============================================
# API IA & CONTENU
# ============================================

# OpenRouter (Claude, GPT-4o mini, etc.)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=AURA_AND_LOGOS

# OpenAI (TTS voix)
OPENAI_API_KEY=

# ============================================
# IMAGES STOCK
# ============================================

# Pixabay
PIXABAY_API_KEY=

# Pexels
PEXELS_API_KEY=

# ============================================
# PAIEMENTS & EMAILS
# ============================================

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PRO_MONTHLY=price_xxx

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@auraandlogos.com

# ============================================
# MAINTENANCE & MONITORING
# ============================================

# Environnement (development / production)
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AURA_AND_LOGOS

# Monitoring (optionnel)
PLAUSIBLE_API_KEY=
SENTRY_DSN=